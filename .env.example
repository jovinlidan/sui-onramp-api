# --- Server ---
PORT=8080
NODE_ENV=development

# --- Alchemy Pay merchant credentials ---
# Get these from the Alchemy Pay merchant dashboard after KYB approval.
# NEVER commit real values. Set them in your deployment platform's env (App Runner / Cloud Run / Vercel / etc.).
ALCHEMY_PAY_APP_ID=
ALCHEMY_PAY_APP_SECRET=

# Production: https://openapi.alchemypay.org
# Sandbox:    https://openapi-test.alchemypay.org
ALCHEMY_PAY_BASE_URL=https://openapi-test.alchemypay.org

# Dev stand-in while the Alchemy merchant account is still pending activation.
# When `true`, /buy/crypto-list returns a static list of common Sui-mainnet
# buyable coins instead of hitting Alchemy. Flip to `false` (or remove) once
# your merchant API access is live.
USE_STUB_CRYPTO_LIST=true
