# Pin pnpm behavior so installs are reproducible across machines.
# Exact versions in package.json + this lockfile policy = the same node_modules
# every install for as long as the registry preserves these versions.

# Refuse to install if pnpm-lock.yaml is missing / out of sync — CI safety net.
frozen-lockfile=true

# Save exact versions (no carets) when adding deps. We've already pinned
# explicitly in package.json; this keeps it that way for any future pnpm add.
save-exact=true

# Don't auto-install peers; surface mismatches explicitly so we don't silently
# pull in unintended versions.
auto-install-peers=false
